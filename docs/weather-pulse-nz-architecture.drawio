                <mxCell id="line-style-legend" value="Legend: dashed = external connection, solid = AWS-internal connection" style="text;html=1;align=left;verticalAlign=middle;resizable=0;autosize=0;fontSize=11;fontColor=light-dark(#333333,#E6E6E6);fontFamily=Helvetica;" vertex="1" parent="1">
                    <mxGeometry x="40" y="708" width="520" height="20" as="geometry"/>
